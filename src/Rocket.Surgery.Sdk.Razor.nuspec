<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
    <metadata>
        <id>Rocket.Surgery.Sdk.Razor</id>
        <version>$version$</version>
        <authors>David Driscoll, Rocket Surgeons Guild contributors</authors>
        <description>Rocket Surgeons Guild MSBuild project SDK for Razor class library projects.</description>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <license type="expression">MIT</license>
        <readme>README.md</readme>
        <projectUrl>https://github.com/RocketSurgeonsGuild/rsg-sdk</projectUrl>
        <repository type="git" url="$RepositoryUrl$" commit="$RepositoryCommit$" branch="$RepositoryBranch$" />
        <tags>msbuild sdk rocketsurgeonsguild conventions analyzers testing</tags>
        <packageTypes>
            <packageType name="MSBuildSdk" />
        </packageTypes>
    </metadata>
    <files>
        <file src="Sdk/Rocket.Surgery.Sdk.Razor/Sdk.props" target="Sdk" />
        <file src="Sdk/Rocket.Surgery.Sdk.Razor/Sdk.targets" target="Sdk" />
        <file src="common/**" target="common" />
        <file src="configuration/**" target="configuration" />
        <file src="../README.md" target="README.md" />
        <file src="../LICENSE" target="LICENSE" />
    </files>
</package>
